{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "out",
    "declaration": false,
    "noEmit": true
  },
  "include": ["electron/**/*.ts", "electron.vite.config.ts"]
}
